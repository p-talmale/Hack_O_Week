<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Travel Planner Pro</title>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

/* ================= THEME VARIABLES ================= */
:root {
  --bg: linear-gradient(135deg, #667eea, #764ba2);
  --card: rgba(255,255,255,0.15);
  --text: #ffffff;
  --accent: #00f2fe;
}

.dark {
  --bg: linear-gradient(135deg, #1e1e2f, #12121c);
  --card: rgba(255,255,255,0.05);
  --text: #ffffff;
  --accent: #00c6ff;
}

* { box-sizing: border-box; }

body {
  margin: 0;
  font-family: 'Segoe UI', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  padding: 40px 20px;
  transition: 0.3s;
}

h1 { margin: 0; }

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* ================= BUTTONS ================= */
button {
  padding: 10px 16px;
  border-radius: 25px;
  border: none;
  cursor: pointer;
  font-weight: bold;
  transition: 0.3s;
}

.primary {
  background: white;
  color: #764ba2;
}

.toggle {
  background: var(--accent);
  color: #000;
}

button:hover { transform: translateY(-2px); }

/* ================= CARD ================= */
.card {
  margin-top: 25px;
  background: var(--card);
  backdrop-filter: blur(12px);
  padding: 20px;
  border-radius: 16px;
  box-shadow: 0 10px 40px rgba(0,0,0,0.3);
}

/* ================= FORM ================= */
input, textarea {
  width: 100%;
  padding: 10px;
  margin-top: 10px;
  border-radius: 8px;
  border: none;
  outline: none;
}

textarea { resize: vertical; min-height: 80px; }

/* ================= OUTPUT ================= */
#output {
  white-space: pre-wrap;
  margin-top: 15px;
}

/* ================= GRID ================= */
.grid {
  display: grid;
  gap: 20px;
}

@media(min-width: 900px) {
  .grid {
    grid-template-columns: 1fr 1fr;
  }
}

/* ================= MAP ================= */
iframe {
  width: 100%;
  height: 300px;
  border-radius: 12px;
  border: none;
}

/* ================= SPINNER ================= */
.spinner {
  display: none;
  margin-top: 10px;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0% { opacity: 0.5 }
  50% { opacity: 1 }
  100% { opacity: 0.5 }
}

</style>
</head>
<body>

<div class="top-bar">
  <h1>✈️ AI Travel Planner Pro</h1>
  <button class="toggle" onclick="toggleTheme()">🌙 Toggle Mode</button>
</div>

<div class="card">
  <h3>Plan Your Trip</h3>

  <input id="destination" placeholder="Destination (Paris)">
  <input id="startDate" type="date">
  <input id="endDate" type="date">
  <input id="budget" placeholder="Budget (USD)">
  <textarea id="preferences" placeholder="Food, adventure, luxury, museums..."></textarea>

  <button class="primary" onclick="submitTrip()">Generate AI Plan</button>
  <div class="spinner" id="spinner">🧠 Generating AI itinerary...</div>
</div>

<div class="grid">

  <div class="card">
    <h3>📋 AI Itinerary</h3>
    <div id="output"></div>
  </div>

  <div class="card">
    <h3>🗺 Location Map</h3>
    <iframe id="map"></iframe>
  </div>

  <div class="card">
    <h3>💰 Budget Breakdown</h3>
    <canvas id="budgetChart"></canvas>
  </div>

  <div class="card">
    <h3>🏨 Hotels & Flights</h3>
    <div id="links"></div>
  </div>

</div>

<script>

/* ================= THEME ================= */
function toggleTheme() {
  document.body.classList.toggle("dark");
}

/* ================= DAYS ================= */
function daysBetween(start, end) {
  const s = new Date(start);
  const e = new Date(end);
  return Math.max(1, Math.ceil((e - s)/(1000*60*60*24)) + 1);
}

/* ================= MAIN ================= */
async function submitTrip() {

  const destination = destinationInput.value;
  const start = startDate.value;
  const end = endDate.value;
  const budget = parseInt(budgetInput.value) || 0;
  const preferences = preferencesInput.value;

  if (!destination || !start || !end) {
    alert("Fill destination and dates");
    return;
  }

  const days = daysBetween(start, end);

  spinner.style.display = "block";
  output.innerText = "";

  /* ===== REAL AI CALL ===== */
  try {
    const response = await fetch("https://api.openai.com/v1/chat/completions", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "Authorization": "Bearer YOUR_OPENAI_API_KEY"
      },
      body: JSON.stringify({
        model: "gpt-4o-mini",
        messages: [{
          role: "user",
          content: `Create a ${days}-day travel itinerary for ${destination}.
          Budget: $${budget}
          Preferences: ${preferences}`
        }]
      })
    });

    const data = await response.json();
    output.innerText = data.choices[0].message.content;

  } catch {
    output.innerText = "AI unavailable. Showing fallback plan.\n\n" +
      generateFallback(destination, days);
  }

  spinner.style.display = "none";

  /* ===== MAP ===== */
  map.src = `https://www.google.com/maps?q=${encodeURIComponent(destination)}&output=embed`;

  /* ===== LINKS ===== */
  links.innerHTML = `
    ✈️ <a href="https://www.google.com/travel/flights?q=flights+to+${destination}" target="_blank">Search Flights</a><br><br>
    🏨 <a href="https://www.booking.com/searchresults.html?ss=${destination}" target="_blank">Find Hotels</a>
  `;

  /* ===== BUDGET CHART ===== */
  const stay = budget * 0.4;
  const food = budget * 0.25;
  const activities = budget * 0.2;
  const transport = budget * 0.15;

  new Chart(document.getElementById('budgetChart'), {
    type: 'doughnut',
    data: {
      labels: ['Stay', 'Food', 'Activities', 'Transport'],
      datasets: [{
        data: [stay, food, activities, transport]
      }]
    }
  });

  localStorage.setItem("trip", JSON.stringify({
    destination, start, end, budget, preferences
  }));
}

/* ================= FALLBACK ================= */
function generateFallback(dest, days) {
  let text = `Trip to ${dest} for ${days} days:\n\n`;
  for (let i=1; i<=days; i++) {
    text += `Day ${i}: Explore top attractions and local cuisine.\n\n`;
  }
  return text;
}

/* ================= INIT ================= */
const destinationInput = document.getElementById("destination");
const startDate = document.getElementById("startDate");
const endDate = document.getElementById("endDate");
const budgetInput = document.getElementById("budget");
const preferencesInput = document.getElementById("preferences");
const output = document.getElementById("output");
const spinner = document.getElementById("spinner");
const map = document.getElementById("map");
const links = document.getElementById("links");



window.onload = () => {
  const saved = JSON.parse(localStorage.getItem("trip"));
  if (saved) {
    destinationInput.value = saved.destination;
    startDate.value = saved.start;
    endDate.value = saved.end;
    budgetInput.value = saved.budget;
    preferencesInput.value = saved.preferences;
  }
};

</script>
</body>
</html>
